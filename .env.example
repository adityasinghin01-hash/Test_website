# ╔════════════════════════════════════════════════════════════╗
# ║  AUTH SYSTEM BACKEND — Environment Variables               ║
# ║  Copy this file to .env and fill in your values            ║
# ╚════════════════════════════════════════════════════════════╝

# ── Server ─────────────────────────────────────────────────
PORT=5001                                    # Server port (Render assigns its own via $PORT)
NODE_ENV=development                         # development | production

# ── Database ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ── JWT Secrets ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Do NOT use human-readable strings like "mysecret123" — use 64 random bytes
JWT_ACCESS_SECRET=                           # 64-byte random hex string
JWT_REFRESH_SECRET=                          # 64-byte random hex string (different from above)
ACCESS_TOKEN_EXPIRES=15m                     # Access token TTL
REFRESH_TOKEN_EXPIRES=7d                     # Refresh token TTL (default, non-rememberMe)

# ── URLs ───────────────────────────────────────────────────
BASE_URL=http://localhost:5001               # Used in verification email links
                                             # In production: https://your-app.onrender.com
CLIENT_URL=http://localhost:3000             # Frontend URL (used in CORS whitelist)

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000         # Comma-separated list of allowed origins
                                             # e.g. https://myapp.com,https://admin.myapp.com

# ── Email (Nodemailer / Gmail SMTP) ───────────────────────
SMTP_HOST=smtp.gmail.com                     # SMTP server
SMTP_PORT=587                                # 587 for TLS, 465 for SSL
SMTP_USER=                                   # Gmail address
SMTP_PASS=                                   # Gmail App Password (not regular password)
EMAIL_FROM=                                  # Sender email (usually same as SMTP_USER)

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=                            # From Google Cloud Console
                                             # Format: xxxxxxxxxxxx.apps.googleusercontent.com
                                             # ❌ WRONG: GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID=xxx (do NOT duplicate key name)

# ── reCAPTCHA ──────────────────────────────────────────────
RECAPTCHA_SECRET=                            # Server-side secret from Google reCAPTCHA admin
                                             # Test key: 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
